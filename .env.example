# Copy values into your environment or project-specific runner
OBSIDIAN_VAULT_PATH=
VIDEO_RESEARCH_INGEST_SUBFOLDER=Research/Video Research Ingest
VIDEO_RESEARCH_INGEST_OUTPUT_DIR=./output
VIDEO_RESEARCH_PRIMARY_SUBTITLE_LANGS=en.*,en
VIDEO_RESEARCH_FALLBACK_SUBTITLE_LANGS=es.*,es

# Transcription strategy
# auto = subtitles first, then local faster-whisper, then optional OpenAI-compatible API
# local = force local faster-whisper only
# openai = force OpenAI-compatible API only
# none = disable transcription fallback beyond subtitles
VIDEO_RESEARCH_TRANSCRIBER=auto
VIDEO_RESEARCH_WHISPER_MODEL=base
VIDEO_RESEARCH_WHISPER_DEVICE=auto
VIDEO_RESEARCH_WHISPER_COMPUTE_TYPE=int8

# Optional paid/API fallback only if you want it
OPENAI_API_KEY=***
GROQ_API_KEY=***
VIDEO_RESEARCH_TRANSCRIBE_BASE_URL=
VIDEO_RESEARCH_OPENAI_TRANSCRIBE_MODEL=whisper-1

# Optional explicit binary path if yt-dlp is not already on PATH
YT_DLP_PATH=/home/your-user/.local/bin/yt-dlp
